res_50_5reps_full = readRDS("./20250821_homo_5reps_raw_res_full.RDS")
res_50_5reps_full = unlist(res_50_5reps_full, F, F)
num_hessians_5rep_full = mclapply(res_50_5reps_full, function(x) {
  ols_optim_problem_noise = IsoHDX3:::getOptimizationProblem(x$data,
                                                             cl_data, time_0_data, und_d, weights = NULL,
                                                             theta = 1)
  if (!is.null(x$fitted)) {
    num_hess = numDeriv::hessian(ols_optim_problem_noise, x$fitted$x)
  } else {
    num_hess = NULL
  }
  x$hessian = num_hess
  x
}, mc.cores = 5)
saveRDS(num_hessians_5rep_full, "./20250821_homo_5reps_hessians_full.RDS")
