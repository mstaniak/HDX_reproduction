aa_symbols = setdiff(Peptides::aaList(), "P")

for (n_segments in num_segments) {
  seg_lengths = sample(2:5, size = n_segments, replace = T, prob = rep(1, 4) / 4)
  seg_seqs = sapply(seg_lengths, function(len) paste0(sample(aa_symbols, len, T), collapse = ""))
  
  seg_dt = data.table(Sequence = seg_seqs,
                      Length = seg_lengths)
  seg_dt[, End := cumsum(Length)]
  seg_dt[, Start := End - Length + 1]
  setnames(seg_dt, paste0("Segment", colnames(seg_dt)))
  seg_dt[, SegmentSigned := paste0(SegmentSequence, "(", SegmentStart, ",", SegmentEnd, ")")]
  
  unused_segs = seg_seqs
  all_used = FALSE
  peptide_sequences = character(0)
  peptide_memberships = matrix(nrow = 0, ncol = length(seg_seqs))
  while (!all_used) {
    next_peptide_seg_len = sample(2:4, 1)    
    next_peptide_seg_len = min(next_peptide_seg_len, length(unused_segs))
    use_segs = c(rep(TRUE, next_peptide_seg_len), rep(FALSE, length(unused_segs) - next_peptide_seg_len))
    peptide_memberships = rbind(peptide_memberships, c(rep(FALSE, length(seg_seqs) - length(unused_segs)), use_segs))
    next_peptide_sequence = paste0(unused_segs[use_segs], collapse = "")
    peptide_sequences = c(peptide_sequences, next_peptide_sequence)
    unused_segs = unused_segs[-1]
    if (length(unused_segs) == 1) {
      all_used = TRUE
    }
  }
  # consider 2 - 3 segments per peptide?? 4 jako modę? 4-6 jako najbardziej typowe, które dają pewną różnorodność w wielkości widma?
  # first check empirically how many segments per peptide (+on average)
}

